rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default safety net: reject all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Users Master Profile Space
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // 2. Transactions (Wallet Transactions) Subcollection
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 3. Sessions (Voice Sessions) Subcollection
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // 4. Transcription Messages Subcollection
        match /messages/{messageId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // Supporting explicit top-level collection matching just in case the client ever targets them directly
    match /wallet_transactions/{transactionId} {
      allow read, write: if request.auth != null && (
        (resource != null && resource.data.user_id == request.auth.uid) ||
        (request.resource != null && request.resource.data.user_id == request.auth.uid)
      );
    }

    match /voice_sessions/{sessionId} {
      allow read, write: if request.auth != null && (
        (resource != null && resource.data.user_id == request.auth.uid) ||
        (request.resource != null && request.resource.data.user_id == request.auth.uid)
      );
    }

    // 5. Global AI Astrologers Configuration (read-only for all, write-only by admin/server)
    match /ai_agents/{agentId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
